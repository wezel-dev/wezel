{
  "toolchain": "cargo",
  "detectPatterns": ["cargo build", "cargo check", "cargo test"],
  "templates": [
    {
      "id": "incremental-build",
      "name": "Incremental build",
      "description": "Cost of rebuilding after a change to a specific crate",
      "steps": [
        {
          "name": "baseline",
          "tool": "exec",
          "inputs": { "cmd": "cargo build --release" }
        },
        {
          "name": "after-change",
          "tool": "exec",
          "inputs": { "cmd": "cargo build --release" }
        }
      ],
      "uiSchema": {
        "fields": [
          {
            "id": "patchCrate",
            "label": "Crate to patch",
            "type": "crate-picker",
            "description": "Which crate gets a stub change to trigger a rebuild"
          },
          {
            "id": "profile",
            "label": "Profile",
            "type": "select",
            "options": ["release", "dev"],
            "default": "release"
          }
        ]
      }
    },
    {
      "id": "cold-build",
      "name": "Cold build",
      "description": "Full from-scratch build time (incremental=0)",
      "steps": [
        {
          "name": "cold",
          "tool": "exec",
          "inputs": {
            "cmd": "cargo build --release",
            "env": { "CARGO_INCREMENTAL": "0" }
          }
        }
      ],
      "uiSchema": {
        "fields": [
          {
            "id": "profile",
            "label": "Profile",
            "type": "select",
            "options": ["release", "dev"],
            "default": "release"
          }
        ]
      }
    },
    {
      "id": "llvm-lines",
      "name": "LLVM lines",
      "description": "Code size impact of changes to a crate",
      "steps": [
        {
          "name": "baseline",
          "tool": "llvm-lines",
          "inputs": {}
        },
        {
          "name": "after-change",
          "tool": "llvm-lines",
          "inputs": {}
        }
      ],
      "uiSchema": {
        "fields": [
          {
            "id": "patchCrate",
            "label": "Crate to patch",
            "type": "crate-picker",
            "description": "Which crate gets a stub change to measure code size delta"
          }
        ]
      }
    }
  ]
}
