{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Aggregation": {
      "description": "How to aggregate measurement values into a conclusion scalar.",
      "enum": [
        "sum",
        "mean",
        "median",
        "max",
        "min"
      ],
      "type": "string"
    },
    "DiffField": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ],
      "description": "Either a boolean (uses `<step.name>.patch`) or an explicit patch filename."
    },
    "EmbeddedSummaryToml": {
      "description": "Summary definition embedded under a step. The summary's `name` and `step` fields are recovered from the map keys (`step.<step>.summary.<name>`).",
      "properties": {
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/definitions/Aggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "How to combine multiple matching values. Omit when the filter is expected to select a single value."
        },
        "bisect": {
          "default": true,
          "description": "Trigger bisection when this summary regresses.",
          "type": "boolean"
        },
        "filter": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "description": "Tag key=value filters applied before aggregation.",
          "type": "object"
        },
        "measurement": {
          "description": "Measurement name (as emitted by the forager) to aggregate over.",
          "type": "string"
        },
        "samples": {
          "default": 1,
          "description": "Number of forager invocations of the step to take. Lint requires all summaries on the same step to agree. Default 1.",
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "measurement"
      ],
      "type": "object"
    },
    "ExperimentStepToml": {
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "tool": {
                "const": "llvm-lines"
              }
            }
          },
          "then": {
            "properties": {
              "package": {
                "description": "Package name (required for workspaces).",
                "type": [
                  "string",
                  "null"
                ]
              },
              "summary": {
                "additionalProperties": {
                  "allOf": [
                    {
                      "$ref": "#/definitions/EmbeddedSummaryToml"
                    },
                    {
                      "properties": {
                        "measurement": {
                          "description": "**`llvm-lines`** — count of LLVM IR lines (or monomorphisation copies) for a function (u64). Filter tags:\n- `summary_unit = \"lines\"` or `\"copies\"` — crate-wide totals (one row each).\n- `function = \"<symbol>\"` + `unit = \"lines\"`|`\"copies\"` — per-function rows."
                        }
                      }
                    }
                  ]
                },
                "type": "object"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "tool": {
                "const": "cargo"
              }
            }
          },
          "then": {
            "properties": {
              "build_target": {
                "allOf": [
                  {
                    "$ref": "#/definitions/PackageSpecifier"
                  }
                ],
                "description": "Build target — either a list of package names or the literal string \"workspace\"."
              },
              "command": {
                "allOf": [
                  {
                    "$ref": "#/definitions/Command"
                  }
                ],
                "description": "Cargo subcommand to invoke (`build`, `bench`, or `test`)."
              },
              "summary": {
                "additionalProperties": {
                  "allOf": [
                    {
                      "$ref": "#/definitions/EmbeddedSummaryToml"
                    },
                    {
                      "properties": {
                        "measurement": {
                          "description": "**`time_ms`** — how long `cargo <command>` took, in milliseconds."
                        }
                      }
                    }
                  ]
                },
                "type": "object"
              }
            },
            "required": [
              "build_target",
              "command"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "tool": {
                "const": "filesize"
              }
            }
          },
          "then": {
            "properties": {
              "glob": {
                "description": "Glob pattern, evaluated against the experiment workspace cwd.",
                "type": "string"
              },
              "summary": {
                "additionalProperties": {
                  "allOf": [
                    {
                      "$ref": "#/definitions/EmbeddedSummaryToml"
                    },
                    {
                      "properties": {
                        "measurement": {
                          "description": "One measurement per matched file. The measurement name is the file's path (relative to cwd); the value is its size in bytes."
                        }
                      }
                    }
                  ]
                },
                "type": "object"
              }
            },
            "required": [
              "glob"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "tool": {
                "const": "exec"
              }
            }
          },
          "then": {
            "properties": {
              "cmd": {
                "description": "Shell command to run.",
                "type": "string"
              },
              "cwd": {
                "description": "Working directory override.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "env": {
                "additionalProperties": {
                  "type": "string"
                },
                "default": {},
                "description": "Extra environment variables.",
                "type": "object"
              },
              "summary": {
                "additionalProperties": {
                  "allOf": [
                    {
                      "$ref": "#/definitions/EmbeddedSummaryToml"
                    },
                    {
                      "properties": {
                        "measurement": {
                          "description": "This forager emits no measurements."
                        }
                      }
                    }
                  ]
                },
                "type": "object"
              }
            },
            "required": [
              "cmd"
            ]
          }
        }
      ],
      "description": "A single step in the experiment. The `tool` field selects a forager plugin; remaining fields are passed to the plugin via `FORAGER_INPUTS` as JSON.",
      "properties": {
        "apply-diff": {
          "anyOf": [
            {
              "$ref": "#/definitions/DiffField"
            },
            {
              "type": "null"
            }
          ],
          "description": "Apply a patch before running this step. `true` uses `<step name>.patch`; a string overrides the filename."
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "additionalProperties": {
            "$ref": "#/definitions/EmbeddedSummaryToml"
          },
          "description": "Summaries emitted by this step, keyed by summary name.",
          "type": "object"
        },
        "tool": {
          "description": "Forager plugin name (resolves to `forager-<tool>`). Required.",
          "type": "string"
        }
      },
      "required": [
        "tool"
      ],
      "type": "object"
    }
  },
  "description": "Top-level shape of `.wezel/experiments/<name>/experiment.toml`.\n\nSteps are a map keyed by step name; insertion order is preserved by the `preserve_order` feature on the `toml` crate plus `IndexMap` here.",
  "properties": {
    "description": {
      "description": "Human-readable description of what the experiment measures.",
      "type": [
        "string",
        "null"
      ]
    },
    "step": {
      "additionalProperties": {
        "$ref": "#/definitions/ExperimentStepToml"
      },
      "description": "Ordered map of step name → step definition. Patches are cumulative.",
      "type": "object"
    }
  },
  "required": [
    "step"
  ],
  "title": "Wezel experiment.toml",
  "type": "object"
}